app:
  name: 文档问答桌面应用
  version: 1.0.0
  organization: MySite
  ui:
    theme: light
    language: zh_CN
    window:
      width: 1200
      height: 800
      maximized: false
    font_size: 12
  data:
    chroma_db_path: .chroma_data/chroma_db
    documents_path: .chroma_data/documents
    config_path: config
ai:
  openai:
    api_key: you-key
    model: GLM-4-Flash
    base_url: https://open.bigmodel.cn/api/paas/v4
  chat:
    temperature: 0.8
    max_tokens: 128000
    top_p: 1.0
    frequency_penalty: 0.0
    presence_penalty: 0.0
  context:
    max_history: 10
    include_context_docs: 5
    max_doc_context_length: 2000
document:
  supported_extensions:
  - .pdf
  - .docx
  - .txt
  - .md
  - .markdown
  processing:
    max_file_size_mb: 10
    chunk_size: 600
    chunk_overlap: 50
  text:
    encoding: utf-8
    min_chunk_length: 50
    max_chunk_length: 2000
vector_db:
  chroma:
    persist_directory: .chroma_data/chroma_db
    collection_name: document_collection
    embedding_model: paraphrase-multilingual-MiniLM-L12-v2
    distance_metric: cosine
  search:
    n_results: 5
    include_metadata: true
    include_distances: false
ui_settings:
  document_panel:
    default_width: 300
    show_file_size: true
    show_upload_time: true
  chat_panel:
    show_timestamps: true
    auto_scroll: true
    max_message_length: 5000
  config_panel:
    show_advanced: false
    auto_save: true
chat:
  stream_response: true
  typing_effect: true
test:
  key: test_value
